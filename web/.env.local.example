VITE_API_URL=http://localhost:8080
VITE_ENV=local
VITE_ANALYTICS_PROVIDER=
VITE_GA4_ID=
VITE_PLAUSIBLE_DOMAIN=
VITE_MIXPANEL_TOKEN=
VITE_SENTRY_DSN=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.15


VITE_FEATURE_REVIEWS=true
VITE_FEATURE_REFERRALS=true
VITE_FEATURE_GRID_MANUAL=true
VITE_FEATURE_GRID_ASSIST=false
VITE_FEATURE_GRID_AUTO=false


VITE_BRAND_NAME=VAiyu
VITE_BRAND_PRIMARY=#0F62FE
VITE_BRAND_ACCENT=#00C853
VITE_BRAND_WARNING=#FF3B30
VITE_BRAND_SUCCESS=#34C759

# Razorpay public key — only the rzp_test_* / rzp_live_* "key id".
# The matching key_secret lives ONLY in Supabase Edge Function secrets
# (RAZORPAY_KEY_SECRET) — never put it here.
VITE_RAZORPAY_KEY_ID=


# ─────────────────────────────────────────────────────────────────────────────
# DEV-ONLY auto sign-in (for Playwright / Claude / browser-agent testing).
# Implemented in web/src/lib/devAuth.ts. Activation requires ALL three:
#   1. A Vite dev build (import.meta.env.DEV === true). A production
#      `vite build` artifact has this constant inlined as false, so the entire
#      devAuth module is dead-code-eliminated — these vars cannot do anything.
#   2. VITE_DEV_AUTH_BYPASS=true (the explicit opt-in below).
#   3. VITE_SUPABASE_URL points at localhost / 127.0.0.1, OR matches the
#      project ref listed in VITE_DEV_AUTH_ALLOWED_PROJECT_REF.
#
# When all three hold, on app boot the app does a real signInWithPassword to
# the seeded user. RLS, RPCs, Edge Functions and Realtime keep working
# exactly as in production — only the OTP step is skipped.
#
# Seed the matching user/hotel by running supabase/seed-dev-auth.sql against
# your LOCAL Supabase. NEVER set these vars in Netlify or any prod env.
# ─────────────────────────────────────────────────────────────────────────────
VITE_DEV_AUTH_BYPASS=false
VITE_DEV_AUTH_EMAIL=dev-owner@vaiyu.test
VITE_DEV_AUTH_PASSWORD=devpassword-change-me
VITE_DEV_AUTH_HOTEL_SLUG=dev-hotel
# Leave empty for localhost-only. Set to a Supabase project ref (e.g. "abcdxyz"
# from https://abcdxyz.supabase.co) ONLY to allow autologin against that
# specific non-local dev project.
VITE_DEV_AUTH_ALLOWED_PROJECT_REF=
